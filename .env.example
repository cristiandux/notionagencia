# Copia este archivo como .env.local y rellena tus valores de Supabase
# Settings → API en tu proyecto Supabase

NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# REQUERIDO para enviar invitaciones por email
# Supabase → Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui
# Opcional para operaciones server-side de base de datos si usas claves nuevas.
# Para enviar emails con supabase.auth.admin.inviteUserByEmail sigue usando SUPABASE_SERVICE_ROLE_KEY.
# SUPABASE_SECRET_KEY=sb_secret_...

# Opcional: envia invitaciones directamente con Resend en vez de SMTP de Supabase.
# RESEND_FROM debe usar un dominio verificado en Resend.
RESEND_API_KEY=re_...
RESEND_FROM=Gonzo Agencia <hola@tu-dominio.com>

# URL pública de tu app (sin slash final)
# Local: http://localhost:3000  |  Producción: https://tu-dominio.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000
